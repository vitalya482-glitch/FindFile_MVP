<UserControl x:Class="FindFile.Desktop.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <StackPanel>
            <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="О программе" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="FindFile — поиск по NAS. GUI: WPF · Indexer: C++." Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Обновления" Style="{StaticResource SectionTitleStyle}" />

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Текущая версия:" Style="{StaticResource LabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentVersion}" Foreground="{StaticResource TextBrush}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Последняя версия:" Style="{StaticResource LabelStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LatestVersion}" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                    </Grid>

                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Проверить обновления" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CheckUpdatesCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
