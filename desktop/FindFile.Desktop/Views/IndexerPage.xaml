<UserControl x:Class="FindFile.Desktop.Views.IndexerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="48" Height="48" CornerRadius="16" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="🗄" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Индексатор" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Настройка индексации файлов и папок" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Папка индексации" Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="Папка индексации" Style="{StaticResource LabelStyle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Settings.RootPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="10,0,0,0" Content="Обзор..." Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseRootCommand}" />
                        </Grid>

                        <TextBlock Text="Путь сохранения индекса" Style="{StaticResource LabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Settings.IndexPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="10,0,0,0" Content="Выбрать..." Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseIndexPathCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Что индексировать" Style="{StaticResource SectionTitleStyle}" />

                        <ItemsControl ItemsSource="{Binding ExtensionOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Title}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Пользовательские расширения" Style="{StaticResource LabelStyle}" Margin="0,12,0,6" />
                        <TextBox Text="{Binding Settings.CustomExtensions, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Расширения указываются через запятую, например: .vsdx, .dwg, .rtf" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Исключения" Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="270" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="Пропускать системные файлы" IsChecked="{Binding Settings.SkipSystemFiles}" />
                                <CheckBox Content="Пропускать скрытые файлы" IsChecked="{Binding Settings.SkipHiddenFiles}" />
                                <CheckBox Content="Пропускать уже проиндексированные" IsChecked="{Binding Settings.SkipAlreadyIndexed}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Исключённые папки (через ; )" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Settings.ExcludeDirs, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="Исключённые маски (через ; )" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding Settings.ExcludeMasks, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Параметры индекса" Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <UniformGrid Grid.Column="0" Columns="2">
                                <CheckBox Content="Имя файла" IsChecked="{Binding Settings.StoreName}" />
                                <CheckBox Content="Путь" IsChecked="{Binding Settings.StorePath}" />
                                <CheckBox Content="Размер" IsChecked="{Binding Settings.StoreSize}" />
                                <CheckBox Content="Дата изменения" IsChecked="{Binding Settings.StoreModifiedTime}" />
                                <CheckBox Content="Расширение" IsChecked="{Binding Settings.StoreExtension}" />
                                <CheckBox Content="Атрибуты" IsChecked="{Binding Settings.StoreAttributes}" />
                                <CheckBox Content="Тип файла" IsChecked="{Binding Settings.StoreFileType}" />
                            </UniformGrid>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Режим индексации" Style="{StaticResource LabelStyle}" />
                                <ComboBox ItemsSource="{Binding IndexModes}" SelectedItem="{Binding Settings.IndexMode}" />
                                <TextBlock Text="full — с нуля&#x0a;update — только изменения&#x0a;resume — продолжить" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Управление" Style="{StaticResource SectionTitleStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶  Старт" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartCommand}" Margin="0,0,10,0" />
                            <Button Content="⏸  Пауза" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PauseCommand}" Margin="0,0,10,0" />
                            <Button Content="▶  Продолжить" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResumeCommand}" Margin="0,0,10,0" />
                            <Button Content="■  Остановить" Style="{StaticResource DangerButtonStyle}" Command="{Binding StopCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <CheckBox Content="Отложенный старт" IsChecked="{Binding Settings.DelayedStart}" />
                            <TextBox Width="80" Text="{Binding Settings.DelayedStartTime}" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Статус" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Статус:" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding Status.State}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Файлов:" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Status.FilesIndexed}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Папок:" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Status.FoldersIndexed}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Ошибок:" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Status.Errors}" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Right" />
                        </Grid>

                        <TextBlock Text="Текущий путь:" Style="{StaticResource LabelStyle}" Margin="0,10,0,4" />
                        <TextBlock Text="{Binding Status.CurrentPath}" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" FontSize="12" />

                        <Grid Margin="0,16,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Прогресс:" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Status.ProgressPercent, StringFormat={}{0:0}%}" />
                        </Grid>
                        <ProgressBar Height="10" Maximum="100" Value="{Binding Status.ProgressPercent}" />

                        <TextBlock Text="Прошло:" Foreground="{StaticResource MutedTextBrush}" Margin="0,16,0,3" />
                        <TextBlock Text="{Binding Status.Elapsed}" />
                        <TextBlock Text="Скорость:" Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,3" />
                        <TextBlock Text="{Binding Status.Speed}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Статистика расширений" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Status.ExtensionStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Extension}" Foreground="{StaticResource TextBrush}" />
                                        <Border Grid.Column="1" Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="8,3">
                                            <TextBlock Text="{Binding Count}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить настройки" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveSettingsCommand}" Margin="0,0,10,0" />
                    <Button Content="Сбросить" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResetSettingsCommand}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
