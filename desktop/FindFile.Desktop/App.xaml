<Application x:Class="FindFile.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FindFile.Desktop.Views"
             xmlns:vm="clr-namespace:FindFile.Desktop.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Общие стили: цвета, кнопки, карточки, поля ввода. -->
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Связка ViewModel -> View. Благодаря этому ContentControl сам показывает нужную страницу. -->
            <DataTemplate DataType="{x:Type vm:IndexerViewModel}">
                <views:IndexerPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SearchViewModel}">
                <views:SearchPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
                <views:ResultsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AboutViewModel}">
                <views:AboutPage />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
