<Window x:Class="FindFile.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FindFile" Height="860" Width="1240"
        MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая навигационная панель. Она не занимается логикой, а только вызывает команды MainViewModel. -->
        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,22,20,16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="38" Height="38" CornerRadius="12" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="F" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FindFile" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="поиск по NAS" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{StaticResource NavButtonStyle}" Content="🔎  Поиск" Command="{Binding ShowSearchCommand}" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="📋  Результаты" Command="{Binding ShowResultsCommand}" />
                    <Button Style="{StaticResource NavButtonActiveStyle}" Content="🗄  Индексатор" Command="{Binding ShowIndexerCommand}" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="⚙  Настройки" Command="{Binding ShowSettingsCommand}" />
                    <Button Style="{StaticResource NavButtonStyle}" Content="ℹ  О программе" Command="{Binding ShowAboutCommand}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="20">
                    <TextBlock Text="Версия 0.2 XAML" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    <TextBlock Text="GUI: WPF · Indexer: C++" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Главная область. Здесь показывается выбранная страница. -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
    </Grid>
</Window>
